[resource]
script = ExtResource("1_profile_script")
profile_name = "Cassian Vale"
age = 31
sex = "Male"
job = "Jeweller and gem setter"
personality = "Charming, articulate, and a little vain. He enjoys beauty, precision, and being admired for his work, though he becomes intensely focused when craft is on the line."
family = "Comes from a once-wealthy merchant family that has seen better days. He now supports a younger sister who studies in the city and sends him long, demanding letters."
intelligence = "Refined and perceptive, with strong aesthetic judgment, nimble hands, and the kind of careful concentration that notices flaws others miss."
memories = PackedStringArray()
